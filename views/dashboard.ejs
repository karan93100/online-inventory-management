<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 bg-dark text-white min-vh-100 p-3">
                <h4 class="text-center mb-4">📦 Inventory</h4>
                <a href="/dashboard" class="nav-link text-white active">Dashboard</a><br>
                <a href="/products" class="nav-link text-white">Products</a><br>
                <a href="/logout" class="nav-link text-danger">Logout</a>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 p-5">
                <h1>Welcome, <%= user.name %>!</h1>
                <p class="lead">You are logged in as <strong><%= user.role.toUpperCase() %></strong></p>
                
                <div class="alert alert-success mt-4">
                    ✅ <strong>Inventory Management System is Working!</strong><br>
                    Full-Stack Project with Node.js + MySQL + Bootstrap is ready.
                </div>

                <a href="/products" class="btn btn-primary btn-lg mt-3">Go to Products →</a>
            </div>
        </div>
    </div>
</body>
</html>